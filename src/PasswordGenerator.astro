---
const githubUrl = 'https://github.com/clearhowguide/private-password-generator';
---

<section class="password-generator" data-password-generator>
  <div class="password-generator__header">
    <p class="password-generator__eyebrow">Private tool</p>

    <h3>Private password generator</h3>

    <p>
      Generate strong passwords locally in your browser. Nothing is saved.
      Nothing is sent. Nothing is tracked.
    </p>
  </div>

  <div class="password-generator__privacy" role="note">
    <strong>Privacy first:</strong>
    This generator runs locally in your browser. Your password is not saved,
    sent, or tracked.
  </div>

  <div class="password-generator__mode-group" aria-label="Password generator mode">
    <button type="button" class="password-generator__mode is-active" data-generator-mode="random">
      Random password
    </button>

    <button type="button" class="password-generator__mode" data-generator-mode="passphrase">
      Memorable passphrase
    </button>

    <button type="button" class="password-generator__mode" data-generator-mode="strengthen">
      Strengthen my idea
    </button>
  </div>

  <div class="password-generator__idea" data-generator-idea-panel hidden>
    <label class="password-generator__label" for="private-password-generator-idea">
      Words, numbers, or hints to strengthen
    </label>

    <textarea
      id="private-password-generator-idea"
      data-generator-idea
      rows="3"
      autocomplete="off"
      spellcheck="false"
      autocapitalize="off"
      placeholder="Example: two random words, a number, or a phrase you want to make stronger"
    ></textarea>

    <p class="password-generator__hint">
      For best security, avoid names, birthdays, addresses, company names, or personal details.
      A fully random password is still the safest option.
    </p>
  </div>

  <div class="password-generator__controls">
    <div class="password-generator__control">
      <div class="password-generator__control-header">
        <label class="password-generator__label" for="private-password-generator-length">
          Length
        </label>

        <output data-generator-length-output for="private-password-generator-length">
          24 characters
        </output>
      </div>

      <div class="password-generator__length-row">
        <input
          id="private-password-generator-length"
          data-generator-length
          type="range"
          min="8"
          max="128"
          value="24"
        />

        <input
          data-generator-length-number
          type="number"
          min="8"
          max="128"
          value="24"
          inputmode="numeric"
          aria-label="Password length"
        />
      </div>
    </div>

    <div class="password-generator__presets" aria-label="Password presets">
      <button type="button" class="password-generator__small-button" data-generator-preset="easy">
        Easy
      </button>

      <button type="button" class="password-generator__small-button" data-generator-preset="strong">
        Strong
      </button>

      <button type="button" class="password-generator__small-button" data-generator-preset="maximum">
        Maximum
      </button>
    </div>

    <div class="password-generator__options">
      <label>
        <input type="checkbox" data-generator-option="lowercase" checked />
        Lowercase
      </label>

      <label>
        <input type="checkbox" data-generator-option="uppercase" checked />
        Uppercase
      </label>

      <label>
        <input type="checkbox" data-generator-option="numbers" checked />
        Numbers
      </label>

      <label>
        <input type="checkbox" data-generator-option="symbols" checked />
        Symbols
      </label>

      <label>
        <input type="checkbox" data-generator-option="ambiguous" checked />
        Avoid ambiguous characters
      </label>

      <label>
        <input type="checkbox" data-generator-option="friendly" />
        Website-friendly symbols
      </label>
    </div>
  </div>

  <div class="password-generator__result" aria-live="polite">
    <label class="password-generator__label" for="private-password-generator-output">
      Generated password
    </label>

    <div class="password-generator__output-row">
      <input
        id="private-password-generator-output"
        data-generator-output
        type="text"
        readonly
        autocomplete="off"
        spellcheck="false"
        autocapitalize="off"
      />

      <button type="button" class="password-generator__small-button" data-generator-copy>
        Copy
      </button>
    </div>

    <div class="password-generator__actions">
      <button type="button" class="password-generator__primary-button" data-generator-generate>
        Generate
      </button>

      <button type="button" class="password-generator__small-button" data-generator-regenerate>
        Regenerate
      </button>
    </div>

    <p class="password-generator__copy-status" data-generator-copy-status>
      Save this password in a trusted password manager. Do not reuse it on other accounts.
    </p>
  </div>

  <div class="password-generator__score-card">
    <div class="password-generator__score-row">
      <div>
        <p class="password-generator__result-label">Strength score</p>
        <p class="password-generator__score" data-generator-score>Not generated yet</p>
      </div>

      <p class="password-generator__crack-time" data-generator-crack-time>
        Generate a password to see an educational crack-time estimate.
      </p>
    </div>

    <div class="password-generator__meter" aria-hidden="true">
      <span data-generator-meter></span>
    </div>

    <div class="password-generator__grid">
      <div class="password-generator__panel">
        <h3>What this generator uses</h3>
        <ul data-generator-summary>
          <li>Waiting for a generated password.</li>
        </ul>
      </div>

      <div class="password-generator__panel">
        <h3>Safety notes</h3>
        <ul data-generator-advice>
          <li>Use a different password for every important account.</li>
          <li>Store generated passwords in a trusted password manager.</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="password-generator__footer">
    <p>
      This estimate is educational. Real security depends on password uniqueness,
      website protections, MFA, breach exposure, and attacker resources.
    </p>

    <a href={githubUrl} target="_blank" rel="noreferrer">
      View source on GitHub -&gt;
    </a>
  </div>
</section>

<script>
  import { zxcvbn, zxcvbnOptions } from '@zxcvbn-ts/core';
  import * as zxcvbnCommonPackage from '@zxcvbn-ts/language-common';
  import * as zxcvbnEnPackage from '@zxcvbn-ts/language-en';

  const options = {
    translations: zxcvbnEnPackage.translations,
    graphs: zxcvbnCommonPackage.adjacencyGraphs,
    dictionary: {
      ...zxcvbnCommonPackage.dictionary,
      ...zxcvbnEnPackage.dictionary,
    },
  };

  zxcvbnOptions.setOptions(options);

  const LOWERCASE = 'abcdefghijklmnopqrstuvwxyz';
  const UPPERCASE = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  const NUMBERS = '0123456789';
  const SYMBOLS = '!@#$%^&*()-_=+[]{};:,.?/|~';
  const FRIENDLY_SYMBOLS = '-_.';
  const AMBIGUOUS = 'O0oIl1';

  const WORDS = [
    'anchor', 'apricot', 'atlas', 'bamboo', 'beacon', 'blossom',
    'canyon', 'cedar', 'cobalt', 'comet', 'coral', 'crystal',
    'delta', 'ember', 'falcon', 'forest', 'galaxy', 'garden',
    'harbor', 'hazel', 'island', 'jasmine', 'kernel', 'lagoon',
    'lantern', 'marble', 'meadow', 'meteor', 'nectar', 'novel',
    'olive', 'onyx', 'orbit', 'pebble', 'pixel', 'prairie',
    'quartz', 'raven', 'river', 'saffron', 'signal', 'silver',
    'summit', 'timber', 'velvet', 'violet', 'willow', 'zephyr'
  ];

  const SCORE_LABELS = [
    'Very weak',
    'Weak',
    'Fair',
    'Strong',
    'Excellent',
  ];

  const SCORE_DESCRIPTIONS = [
    'Too easy to guess.',
    'Still weak for important accounts.',
    'Better, but more length or randomness would help.',
    'Strong for many normal uses if it is unique.',
    'Excellent. Long, uncommon, and hard to guess.',
  ];

  function countCharacters(value) {
    return Array.from(value).length;
  }

  function secureInteger(maxExclusive) {
    if (maxExclusive <= 0) return 0;

    const array = new Uint32Array(1);
    const limit = Math.floor(0x100000000 / maxExclusive) * maxExclusive;

    do {
      crypto.getRandomValues(array);
    } while (array[0] >= limit);

    return array[0] % maxExclusive;
  }

  function pickOne(value) {
    return value[secureInteger(value.length)] ?? '';
  }

  function shuffleItems(items) {
    const copy = [...items];

    for (let index = copy.length - 1; index > 0; index -= 1) {
      const swapIndex = secureInteger(index + 1);
      const current = copy[index];
      copy[index] = copy[swapIndex];
      copy[swapIndex] = current;
    }

    return copy;
  }

  function removeAmbiguousCharacters(value) {
    return Array.from(value).filter((character) => !AMBIGUOUS.includes(character)).join('');
  }

  function getSettings(generator) {
    const lengthInput = generator.querySelector('[data-generator-length]');
    const lowerInput = generator.querySelector('[data-generator-option="lowercase"]');
    const upperInput = generator.querySelector('[data-generator-option="uppercase"]');
    const numberInput = generator.querySelector('[data-generator-option="numbers"]');
    const symbolInput = generator.querySelector('[data-generator-option="symbols"]');
    const ambiguousInput = generator.querySelector('[data-generator-option="ambiguous"]');
    const friendlyInput = generator.querySelector('[data-generator-option="friendly"]');

    return {
      length: clampLength(Number(lengthInput?.value ?? 24)),
      lowercase: Boolean(lowerInput?.checked),
      uppercase: Boolean(upperInput?.checked),
      numbers: Boolean(numberInput?.checked),
      symbols: Boolean(symbolInput?.checked),
      avoidAmbiguous: Boolean(ambiguousInput?.checked),
      websiteFriendly: Boolean(friendlyInput?.checked),
    };
  }

  function clampLength(value) {
    if (!Number.isFinite(value)) return 24;
    return Math.min(128, Math.max(8, Math.round(value)));
  }

  function buildCharacterGroups(settings) {
    const groups = [];

    if (settings.lowercase) groups.push(LOWERCASE);
    if (settings.uppercase) groups.push(UPPERCASE);
    if (settings.numbers) groups.push(NUMBERS);

    if (settings.symbols) {
      groups.push(settings.websiteFriendly ? FRIENDLY_SYMBOLS : SYMBOLS);
    }

    return groups
      .map((group) => settings.avoidAmbiguous ? removeAmbiguousCharacters(group) : group)
      .filter(Boolean);
  }

  function buildCharacterPool(settings) {
    return buildCharacterGroups(settings).join('');
  }

  function generateRandomPassword(settings) {
    const groups = buildCharacterGroups(settings);
    const pool = groups.join('');

    if (!pool) return '';

    const requiredCharacters = groups.map((group) => pickOne(group));
    const remainingLength = Math.max(0, settings.length - requiredCharacters.length);
    const characters = [...requiredCharacters];

    for (let index = 0; index < remainingLength; index += 1) {
      characters.push(pickOne(pool));
    }

    return shuffleItems(characters).join('').slice(0, settings.length);
  }

  function getPassphraseWordCount(length) {
    if (length < 24) return 4;
    if (length < 40) return 5;
    if (length < 56) return 6;
    return 7;
  }

  function generatePassphrase(settings) {
    const separator = settings.websiteFriendly ? '-' : pickOne(['-', '.', '_']);
    const wordCount = getPassphraseWordCount(settings.length);
    const words = [];

    for (let index = 0; index < wordCount; index += 1) {
      let word = pickOne(WORDS);

      if (settings.uppercase && secureInteger(3) === 0) {
        word = word.charAt(0).toUpperCase() + word.slice(1);
      }

      words.push(word);
    }

    let passphrase = words.join(separator);

    if (settings.numbers) {
      passphrase += `${separator}${secureInteger(90) + 10}`;
    }

    if (settings.symbols && !settings.websiteFriendly) {
      passphrase += pickOne('!@#$%');
    }

    while (countCharacters(passphrase) < settings.length) {
      passphrase += pickOne(buildCharacterPool(settings) || LOWERCASE);
    }

    return Array.from(passphrase).slice(0, settings.length).join('');
  }

  function transformIdeaToken(token) {
    const replacements = {
      a: '@',
      e: '3',
      i: '!',
      o: '0',
      s: '$',
    };

    return Array.from(token).map((character) => {
      const lower = character.toLowerCase();

      if (replacements[lower] && secureInteger(2) === 0) {
        return replacements[lower];
      }

      if (/[a-z]/i.test(character) && secureInteger(2) === 0) {
        return character.toUpperCase();
      }

      return character;
    }).join('');
  }

  function generateStrengthenedIdea(settings, idea) {
    const pool = buildCharacterPool(settings) || `${LOWERCASE}${UPPERCASE}${NUMBERS}`;
    const rawTokens = idea
      .trim()
      .split(/[^a-zA-Z0-9]+/)
      .map((token) => token.slice(0, 12))
      .filter((token) => token.length >= 2)
      .slice(0, 4);

    const tokens = rawTokens.length > 0 ? rawTokens : [pickOne(WORDS), pickOne(WORDS)];
    const pieces = [];

    for (const token of tokens) {
      pieces.push(transformIdeaToken(token));
      pieces.push(pickOne(pool));
      pieces.push(String(secureInteger(90) + 10));
    }

    while (pieces.join('').length < settings.length) {
      pieces.push(pickOne(pool));
    }

    return shuffleItems(Array.from(pieces.join(''))).slice(0, settings.length).join('');
  }

  function getMode(generator) {
    return generator.dataset.mode || 'random';
  }

  function generatePassword(generator) {
    const settings = getSettings(generator);
    const mode = getMode(generator);
    const ideaInput = generator.querySelector('[data-generator-idea]');
    const idea = String(ideaInput?.value ?? '');

    if (mode === 'passphrase') {
      return generatePassphrase(settings);
    }

    if (mode === 'strengthen') {
      return generateStrengthenedIdea(settings, idea);
    }

    return generateRandomPassword(settings);
  }

  function renderList(element, items) {
    if (!element) return;

    element.innerHTML = '';

    for (const item of items) {
      const li = document.createElement('li');
      li.textContent = item;
      element.appendChild(li);
    }
  }

  function getCharacterSummary(password, settings, mode) {
    const summary = [];

    summary.push(`${countCharacters(password)} characters`);
    summary.push(`Mode: ${mode === 'random' ? 'Random password' : mode === 'passphrase' ? 'Memorable passphrase' : 'Strengthen my idea'}`);

    if (settings.lowercase) summary.push('Lowercase enabled');
    if (settings.uppercase) summary.push('Uppercase enabled');
    if (settings.numbers) summary.push('Numbers enabled');
    if (settings.symbols) summary.push(settings.websiteFriendly ? 'Website-friendly symbols enabled' : 'Symbols enabled');
    if (settings.avoidAmbiguous) summary.push('Ambiguous characters avoided');

    return summary;
  }

  function getAdvice(password, mode, score) {
    const advice = [];

    advice.push('Save this password in a trusted password manager.');
    advice.push('Do not reuse it on other accounts.');

    if (countCharacters(password) < 16) {
      advice.push('Use at least 16 characters when the website allows it.');
    }

    if (mode === 'strengthen') {
      advice.push('A fully random password is safer than a password based on personal words.');
    }

    if (mode === 'passphrase') {
      advice.push('Passphrases are best when you need something easier to type manually.');
    }

    if (score >= 3) {
      advice.push('Turn on MFA or 2FA for important accounts whenever possible.');
    }

    return advice;
  }

  function updateLength(generator, value) {
    const safeLength = clampLength(value);
    const rangeInput = generator.querySelector('[data-generator-length]');
    const numberInput = generator.querySelector('[data-generator-length-number]');
    const output = generator.querySelector('[data-generator-length-output]');

    if (rangeInput) rangeInput.value = String(safeLength);
    if (numberInput) numberInput.value = String(safeLength);
    if (output) output.textContent = `${safeLength} characters`;
  }

  function updateScore(generator, password) {
    const settings = getSettings(generator);
    const mode = getMode(generator);
    const scoreElement = generator.querySelector('[data-generator-score]');
    const crackTimeElement = generator.querySelector('[data-generator-crack-time]');
    const meterElement = generator.querySelector('[data-generator-meter]');
    const summaryElement = generator.querySelector('[data-generator-summary]');
    const adviceElement = generator.querySelector('[data-generator-advice]');

    if (!password) {
      generator.dataset.strength = 'empty';

      if (scoreElement) scoreElement.textContent = 'Not generated yet';
      if (crackTimeElement) {
        crackTimeElement.textContent = 'Generate a password to see an educational crack-time estimate.';
      }
      if (meterElement) meterElement.style.width = '0%';

      renderList(summaryElement, ['Waiting for a generated password.']);
      renderList(adviceElement, [
        'Use a different password for every important account.',
        'Store generated passwords in a trusted password manager.',
      ]);

      return;
    }

    const result = zxcvbn(password);
    const score = result.score;
    const display = result.crackTimesDisplay?.offlineFastHashing1e10PerSecond ?? 'unknown';

    generator.dataset.strength = String(score);

    if (scoreElement) {
      scoreElement.textContent = `${SCORE_LABELS[score]} · ${countCharacters(password)} characters`;
    }

    if (crackTimeElement) {
      crackTimeElement.textContent = `Estimated powerful offline attack time: ${display}. ${SCORE_DESCRIPTIONS[score]}`;
    }

    if (meterElement) {
      meterElement.style.width = `${((score + 1) / 5) * 100}%`;
    }

    renderList(summaryElement, getCharacterSummary(password, settings, mode));
    renderList(adviceElement, getAdvice(password, mode, score));
  }

  function setPreset(generator, preset) {
    const optionsMap = {
      easy: {
        length: 16,
        lowercase: true,
        uppercase: true,
        numbers: true,
        symbols: false,
        ambiguous: true,
        friendly: true,
      },
      strong: {
        length: 24,
        lowercase: true,
        uppercase: true,
        numbers: true,
        symbols: true,
        ambiguous: true,
        friendly: false,
      },
      maximum: {
        length: 64,
        lowercase: true,
        uppercase: true,
        numbers: true,
        symbols: true,
        ambiguous: true,
        friendly: false,
      },
    };

    const selected = optionsMap[preset] || optionsMap.strong;

    updateLength(generator, selected.length);

    for (const [key, value] of Object.entries(selected)) {
      if (key === 'length') continue;

      const option = generator.querySelector(`[data-generator-option="${key}"]`);
      if (option) option.checked = value;
    }
  }

  function renderGeneratedPassword(generator) {
    const output = generator.querySelector('[data-generator-output]');
    const status = generator.querySelector('[data-generator-copy-status]');
    const password = generatePassword(generator);

    if (output) {
      output.value = password;
    }

    if (status) {
      status.textContent = 'Save this password in a trusted password manager. Do not reuse it on other accounts.';
    }

    updateScore(generator, password);
  }

  document.querySelectorAll('[data-password-generator]').forEach((generator) => {
    const modeButtons = generator.querySelectorAll('[data-generator-mode]');
    const ideaPanel = generator.querySelector('[data-generator-idea-panel]');
    const lengthInput = generator.querySelector('[data-generator-length]');
    const lengthNumber = generator.querySelector('[data-generator-length-number]');
    const presetButtons = generator.querySelectorAll('[data-generator-preset]');
    const generateButton = generator.querySelector('[data-generator-generate]');
    const regenerateButton = generator.querySelector('[data-generator-regenerate]');
    const copyButton = generator.querySelector('[data-generator-copy]');
    const output = generator.querySelector('[data-generator-output]');
    const status = generator.querySelector('[data-generator-copy-status]');

    generator.dataset.mode = 'random';
    updateLength(generator, 24);

    modeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const mode = button.getAttribute('data-generator-mode') || 'random';
        generator.dataset.mode = mode;

        modeButtons.forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');

        if (ideaPanel) {
          ideaPanel.hidden = mode !== 'strengthen';
        }

        renderGeneratedPassword(generator);
      });
    });

    lengthInput?.addEventListener('input', () => {
      updateLength(generator, Number(lengthInput.value));
    });

    lengthInput?.addEventListener('change', () => {
      renderGeneratedPassword(generator);
    });

    lengthNumber?.addEventListener('input', () => {
      updateLength(generator, Number(lengthNumber.value));
    });

    lengthNumber?.addEventListener('change', () => {
      renderGeneratedPassword(generator);
    });

    presetButtons.forEach((button) => {
      button.addEventListener('click', () => {
        setPreset(generator, button.getAttribute('data-generator-preset') || 'strong');
        renderGeneratedPassword(generator);
      });
    });

    generator.querySelectorAll('[data-generator-option]').forEach((option) => {
      option.addEventListener('change', () => {
        const settings = getSettings(generator);

        if (!buildCharacterPool(settings)) {
          const lowercase = generator.querySelector('[data-generator-option="lowercase"]');
          if (lowercase) lowercase.checked = true;
        }

        renderGeneratedPassword(generator);
      });
    });

    generateButton?.addEventListener('click', () => {
      renderGeneratedPassword(generator);
    });

    regenerateButton?.addEventListener('click', () => {
      renderGeneratedPassword(generator);
    });

    copyButton?.addEventListener('click', async () => {
      const password = String(output?.value ?? '');

      if (!password) return;

      try {
        await navigator.clipboard.writeText(password);

        if (status) {
          status.textContent = 'Copied. Save it in your password manager before leaving this page.';
        }
      } catch {
        if (status) {
          status.textContent = 'Copy is not available in this browser. Select the password and copy it manually.';
        }
      }
    });

    renderGeneratedPassword(generator);
  });
</script>

<style>
  .password-generator {
    margin: 2.25rem 0;
    padding: 1.35rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    background:
      radial-gradient(circle at top left, rgba(37, 99, 235, 0.12), transparent 26rem),
      var(--surface-strong, var(--surface));
    box-shadow: var(--shadow-card);
  }

  .password-generator__header {
    max-width: 760px;
  }

  .password-generator__eyebrow {
    margin: 0 0 0.5rem;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .password-generator h3 {
    margin: 0 0 0.65rem;
    font-size: 1rem;
  }

  .password-generator__privacy {
    margin: 1rem 0;
    padding: 0.9rem 1rem;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: var(--surface);
    color: var(--text);
  }

  .password-generator__mode-group {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
    margin: 1rem 0;
  }

  .password-generator__mode,
  .password-generator__small-button,
  .password-generator__primary-button {
    min-height: 46px;
    padding: 0.7rem 0.95rem;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    font: inherit;
    font-weight: 800;
  }

  .password-generator__mode:hover,
  .password-generator__small-button:hover,
  .password-generator__primary-button:hover {
    border-color: var(--accent);
  }

  .password-generator__mode.is-active,
  .password-generator__primary-button {
    border-color: var(--accent);
    background: var(--accent);
    color: white;
  }

  .password-generator__idea,
  .password-generator__controls,
  .password-generator__result,
  .password-generator__score-card {
    margin-top: 1rem;
  }

  .password-generator__controls,
  .password-generator__score-card {
    display: grid;
    gap: 1rem;
  }

  .password-generator__control {
    display: grid;
    gap: 0.65rem;
  }

  .password-generator__control-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
  }

  .password-generator__label,
  .password-generator__result-label {
    margin: 0;
    color: var(--text);
    font-weight: 800;
  }

  .password-generator output {
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 750;
  }

  .password-generator__length-row,
  .password-generator__output-row {
    display: grid;
